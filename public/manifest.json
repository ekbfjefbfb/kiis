  "shortcuts": [
    {
      "name": "Grabar Clase",
      "short_name": "Grabar",
      "description": "Iniciar grabación de clase rápida",
      "url": "/dashboard",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Grabación IA",
      "short_name": "IA Live",
      "description": "Grabación con análisis en tiempo real",
      "url": "/live",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Mis Notas",
      "short_name": "Notas",
      "description": "Ver todas mis notas",
      "url": "/notes",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Chat IA",
      "short_name": "Chat",
      "description": "Hablar con el asistente",
      "url": "/chat",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    }
